@model HairSalonDemo.Models.Sale
@{
    ViewData["Title"] = "Sale Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Sale Details</h1>
        <p class="section-subtitle mb-0">Full breakdown of this checkout.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.SaleId" class="btn btn-secondary">Edit</a>
        <a asp-action="Index" class="btn btn-primary">Back to Sales</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="panel p-4 h-100">
            <h4 class="mb-3">Summary</h4>
            <dl class="row mb-0">
                <dt class="col-sm-5">Customer</dt>
                <dd class="col-sm-7">@(Model.Customer?.FullName ?? "Walk-in")</dd>

                <dt class="col-sm-5">Staff</dt>
                <dd class="col-sm-7">@(Model.Staff?.FullName ?? "N/A")</dd>

                <dt class="col-sm-5">Date</dt>
                <dd class="col-sm-7">@Model.SaleDate.ToString("dd MMM yyyy HH:mm")</dd>

                <dt class="col-sm-5">Payment</dt>
                <dd class="col-sm-7">@Model.PaymentMethod</dd>

                <dt class="col-sm-5">Subtotal</dt>
                <dd class="col-sm-7">@Model.Subtotal.ToString("C")</dd>

                <dt class="col-sm-5">Discount</dt>
                <dd class="col-sm-7">@Model.DiscountAmount.ToString("C")</dd>

                <dt class="col-sm-5">Total Amount</dt>
                <dd class="col-sm-7 fw-bold">@Model.TotalAmount.ToString("C")</dd>
            </dl>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="panel p-4 h-100">
            <h4 class="mb-3">Items Sold</h4>
            @if (Model.SaleItems != null && Model.SaleItems.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Item</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th>Line Total</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.SaleItems)
                        {
                            <tr>
                                <td>@item.ItemType</td>
                                <td>@item.Description</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("C")</td>
                                <td>@item.LineTotal.ToString("C")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="section-subtitle mb-0">No sale items found.</p>
            }
        </div>
    </div>
</div>
