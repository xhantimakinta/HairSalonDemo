@model IEnumerable<HairSalonDemo.Models.Sale>
@{
    ViewData["Title"] = "Sales";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Sales</h1>
        <p class="section-subtitle mb-0">Track every completed checkout.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">New Sale</a>
</div>

@if (TempData["LowStockWarning"] != null)
{
    <div class="alert alert-warning">@TempData["LowStockWarning"]</div>
}

<div class="panel p-4">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Customer</th>
                    <th>Staff</th>
                    <th>Items</th>
                    <th>Payment</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.SaleDate.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@(item.Customer?.FullName ?? "Walk-in")</td>
                    <td>@(item.Staff?.FullName ?? "N/A")</td>
                    <td>@(item.SaleItems?.Count ?? 0)</td>
                    <td>@item.PaymentMethod</td>
                    <td>@item.TotalAmount.ToString("C")</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.SaleId" class="btn btn-sm btn-outline-warning">View</a>
                        <a asp-action="Edit" asp-route-id="@item.SaleId" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.SaleId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
