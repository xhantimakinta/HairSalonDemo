@model IEnumerable<HairSalonDemo.Models.WalkInQueueItem>
@{
    ViewData["Title"] = "Walk-in Queue";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Walk-in Queue</h1>
        <p class="section-subtitle mb-0">Track customers without appointments.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add Walk-in</a>
</div>
<div class="panel p-4">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Customer</th><th>Staff</th><th>Status</th><th>Added</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CustomerName</td>
                    <td>@(item.Staff?.FullName ?? "Not assigned")</td>
                    <td>@item.Status</td>
                    <td>@item.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                    <td class="text-end"><a asp-action="Edit" asp-route-id="@item.WalkInQueueItemId" class="btn btn-sm btn-outline-secondary">Edit</a> <a asp-action="Delete" asp-route-id="@item.WalkInQueueItemId" class="btn btn-sm btn-outline-danger">Delete</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
