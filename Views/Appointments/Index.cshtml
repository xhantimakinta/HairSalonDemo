@model IEnumerable<HairSalonDemo.Models.Appointment>
@{
    ViewData["Title"] = "Appointments";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Appointments</h1>
        <p class="section-subtitle mb-0">Manage salon bookings for clients.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">New Appointment</a>
</div>
<div class="panel p-4">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Date</th><th>Time</th><th>Customer</th><th>Staff</th><th>Service</th><th>Status</th><th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AppointmentDate.ToString("dd MMM yyyy")</td>
                    <td>@item.AppointmentTime.ToString(@"hh\:mm")</td>
                    <td>@item.Customer?.FullName</td>
                    <td>@item.Staff?.FullName</td>
                    <td>@item.Service?.Name</td>
                    <td>@item.Status</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-warning">View</a>
                        <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
