@model HairSalonDemo.Models.Appointment
@{
    ViewData["Title"] = "Appointment Details";
}
<div class="panel p-4">
    <h1 class="mb-3">Appointment Details</h1>
    <dl class="row mb-4">
        <dt class="col-sm-3">Customer</dt><dd class="col-sm-9">@Model.Customer?.FullName</dd>
        <dt class="col-sm-3">Staff</dt><dd class="col-sm-9">@Model.Staff?.FullName</dd>
        <dt class="col-sm-3">Service</dt><dd class="col-sm-9">@Model.Service?.Name</dd>
        <dt class="col-sm-3">Date</dt><dd class="col-sm-9">@Model.AppointmentDate.ToString("dd MMM yyyy")</dd>
        <dt class="col-sm-3">Time</dt><dd class="col-sm-9">@Model.AppointmentTime.ToString(@"hh\:mm")</dd>
        <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
    </dl>
    <div class="d-flex gap-2"><a asp-action="Edit" asp-route-id="@Model.AppointmentId" class="btn btn-primary">Edit</a><a asp-action="Index" class="btn btn-secondary">Back</a></div>
</div>
